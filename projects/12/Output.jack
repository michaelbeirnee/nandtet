    function void moveCursor(int row, int col) {
        if ((row < 0) | (row > 22) | (col < 0) | (col > 63)) {
            do Sys.error(20);
        }
        let curRow = row;
        let curCol = col;
        return;
    }

    function void printChar(char c) {
        var int base, pixY, wordAddr, row, bitmap, mask;
        if (c = 128) { do Output.println();   return; }
        if (c = 129) { do Output.backSpace(); return; }

        let base    = (c - 32) * 11;
        let pixY    = curRow * 11;

        let row = 0;
        while (row < 11) {
            let bitmap  = charMaps[base + row];
            let wordAddr = (pixY + row) * 32 + (curCol / 2);

            if ((curCol & 1) = 0) {

                let mask = Memory.peek(16384 + wordAddr) & (-256);
                do Memory.poke(16384 + wordAddr, mask | bitmap);
            } else {

                let mask = Memory.peek(16384 + wordAddr) & 255;
                do Memory.poke(16384 + wordAddr, mask | (bitmap * 256));
            }
            let row = row + 1;
        }

        let curCol = curCol + 1;
        if (curCol > 63) { do Output.println(); }
        return;
    }

    function void println() {
        let curCol = 0;
        let curRow = curRow + 1;
        if (curRow > 22) { let curRow = 0; }
        return;
    }

    function void backSpace() {
        if (curCol > 0) { let curCol = curCol - 1; }
        do Output.printChar(32);
        if (curCol > 0) { let curCol = curCol - 1; }
        return;
    }

    function void printString(String s) {
        var int i;
        let i = 0;
        while (i < s.length()) {
            do Output.printChar(s.charAt(i));
            let i = i + 1;
        }
        return;
    }

    function void printInt(int n) {
        var String s;
        let s = String.new(6);
        do s.setInt(n);
        do Output.printString(s);
        do s.dispose();
        return;
    }
}
