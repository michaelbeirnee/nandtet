    function void init() {
        let charMaps = Array.new(1056);
        let curRow = 0;
        let curCol = 0;
        do Output.initFont();
        do Screen.clearScreen();
        return;
    }

    function void create(int idx,
                         int r0,  int r1,  int r2,  int r3,
                         int r4,  int r5,  int r6,  int r7,
                         int r8,  int r9,  int r10) {
        var int b;
        let b = idx * 11;
        let charMaps[b]      = r0;  let charMaps[b + 1]  = r1;
        let charMaps[b + 2]  = r2;  let charMaps[b + 3]  = r3;
        let charMaps[b + 4]  = r4;  let charMaps[b + 5]  = r5;
        let charMaps[b + 6]  = r6;  let charMaps[b + 7]  = r7;
        let charMaps[b + 8]  = r8;  let charMaps[b + 9]  = r9;
        let charMaps[b + 10] = r10;
        return;
    }

