CHIP PC {
    IN in[16], load, inc, reset;
    OUT out[16];

    // Priority (highest first): reset > load > inc > hold
    // Register always latches; we compute what to latch via a mux chain.
    PARTS:
    Register(in=next, load=true, out=cur, out=out);
    Inc16(in=cur, out=curPlus1);
    Mux16(a=cur,      b=curPlus1, sel=inc,   out=afterInc);
    Mux16(a=afterInc, b=in,       sel=load,  out=afterLoad);
    Mux16(a=afterLoad, b=false,   sel=reset, out=next);
}
